# ILI9881C MIPI-DSI panel driver
# Build anywhere: just run 'make'
#
# NOTE: Before building, ensure these files are in the current directory
# without the "ili9881c_" prefix:
#   panel-ilitek-ili9881c.c
#   panel-ili9881c.c

obj-m := panel-ili9881c.o

KERNEL_SRC ?= /lib/modules/$(shell uname -r)/build

all: modules

modules:
	@[ -d "$(KERNEL_SRC)" ] || { \
		echo "ERROR: Kernel headers not found at $(KERNEL_SRC)"; \
		echo "Install with: sudo apt install linux-headers-$(shell uname -r)"; \
		exit 1; \
	}
	$(MAKE) -C $(KERNEL_SRC) M=$(CURDIR) modules

install:
	sudo cp panel-ili9881c.ko /lib/modules/$(shell uname -r)/kernel/drivers/gpu/drm/panel/
	sudo depmod -a

clean:
	$(MAKE) -C $(KERNEL_SRC) M=$(CURDIR) clean
